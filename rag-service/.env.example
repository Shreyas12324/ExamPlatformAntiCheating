# RAG Service Environment Configuration
# ======================================
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8002
ENVIRONMENT=development

# Groq API Key (required for LLM)
GROQ_API_KEY=your_groq_api_key_here

# LLM Configuration (optional - defaults shown)
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.7

# Embedding Configuration (optional - defaults shown)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking Configuration (optional - defaults shown)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Configuration (optional - defaults shown)
RETRIEVAL_TOP_K=4

# Session Configuration (optional - defaults shown)
SESSION_TIMEOUT_MINUTES=60
MAX_SESSIONS=100

# File Upload Configuration (optional - defaults shown)
MAX_FILE_SIZE_MB=50
